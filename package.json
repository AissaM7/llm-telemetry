{
  "name": "@llm-telemetry/react-native",
  "version": "1.0.1",
  "description": "Production-ready, provider-agnostic LLM observability SDK for React Native. Auto-instruments any AI chat or search feature with OpenTelemetry traces, RAG quality metrics, and automated evaluation scores.",
  "author": "Aissa Mdouh <aissa@llm-telemetry.dev>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "source": "src/index.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "grafana",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "react-native",
    "opentelemetry",
    "llm",
    "observability",
    "tracing",
    "ai",
    "gpt",
    "anthropic",
    "rag",
    "evaluation",
    "grafana",
    "tempo",
    "loki"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AissaM7/llm-telemetry.git"
  },
  "homepage": "https://github.com/AissaM7/llm-telemetry#readme",
  "bugs": {
    "url": "https://github.com/AissaM7/llm-telemetry/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "@react-native-async-storage/async-storage": ">=1.18.0"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": false
    },
    "react-native-device-info": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@types/jest": "^29.5.11",
    "@types/react-native": "^0.72.8",
    "jest": "^29.7.0",
    "react-native": "^0.73.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
