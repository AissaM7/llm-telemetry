# ═══════════════════════════════════════════════════════════
# @llm-telemetry/react-native — Environment Configuration
# ═══════════════════════════════════════════════════════════
# NOTE: This SDK uses a config object, NOT process.env.
# This file documents available configuration for reference.

# Exporter selection
LLM_TELEMETRY_EXPORTER=otlp-http

# Grafana Tempo (OTLP HTTP)
LLM_TELEMETRY_COLLECTOR_URL=http://localhost:4318

# Grafana Loki (for log export)
LLM_TELEMETRY_LOKI_URL=http://localhost:3100

# Datadog
# LLM_TELEMETRY_EXPORTER=datadog
# LLM_TELEMETRY_DATADOG_API_KEY=your-key

# Honeycomb
# LLM_TELEMETRY_EXPORTER=honeycomb
# LLM_TELEMETRY_HONEYCOMB_API_KEY=your-key
# LLM_TELEMETRY_HONEYCOMB_DATASET=llm-traces

# Evaluation (LLM-as-judge)
LLM_TELEMETRY_EVAL_ENABLED=true
LLM_TELEMETRY_EVAL_API_KEY=your-openai-key
LLM_TELEMETRY_EVAL_MODEL=gpt-4o

# App identity
LLM_TELEMETRY_SERVICE_NAME=my-llm-app
LLM_TELEMETRY_ENVIRONMENT=production
